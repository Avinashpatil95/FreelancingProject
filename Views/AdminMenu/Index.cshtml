@model IEnumerable<RestaurantWebsite.Models.MenuItem>

<div class="container mt-5">

    <h2>Manage Menu</h2>

    <a href="/AdminMenu/Create" class="btn btn-success">
        + Add Menu Item
    </a>

    <table class="table mt-4">

        <thead>
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Available</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>

                        @if (item.ImageData != null)
                        {
                            <img src="@Url.Action("GetImage", "Menu", new { id = item.Id })"
                                 style="width:80px;height:60px;object-fit:cover;" />
                        }

                    </td>

                    <td>
                        @item.Name
                    </td>

                    <td>
                        @item.Category?.Name
                    </td>

                    <td>
                        ₹ @item.Price
                    </td>

                    <td>

                        @if (item.IsAvailable)
                        {
                            <span class="text-success">Yes</span>
                        }
                        else
                        {
                            <span class="text-danger">No</span>
                        }

                    </td>

                    <td>

                        <a class="btn btn-danger"
                           href="/AdminMenu/Delete/@item.Id">
                            Delete
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>
